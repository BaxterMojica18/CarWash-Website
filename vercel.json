{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/dashboard", "destination": "/frontend/dashboard.html" },
    { "source": "/invoices", "destination": "/frontend/invoices.html" },
    { "source": "/order-management", "destination": "/frontend/order-management.html" },
    { "source": "/queue-management", "destination": "/frontend/queue-management.html" },
    { "source": "/products", "destination": "/frontend/products.html" },
    { "source": "/services", "destination": "/frontend/services.html" },
    { "source": "/reports", "destination": "/frontend/reports.html" },
    { "source": "/settings", "destination": "/frontend/settings.html" },
    { "source": "/permissions-management", "destination": "/frontend/permissions-management.html" },
    { "source": "/sidebar-management", "destination": "/frontend/sidebar-management.html" },
    { "source": "/coupon-management", "destination": "/frontend/coupon-management.html" },
    { "source": "/flash-sale-management", "destination": "/frontend/flash-sale-management.html" },
    { "source": "/client-dashboard", "destination": "/frontend/client-dashboard.html" },
    { "source": "/client-orders", "destination": "/frontend/client-orders.html" },
    { "source": "/shop", "destination": "/frontend/shop.html" },
    { "source": "/cart", "destination": "/frontend/cart.html" },
    { "source": "/reserve", "destination": "/frontend/reserve.html" },
    { "source": "/vouchers", "destination": "/frontend/vouchers.html" },
    { "source": "/checkout", "destination": "/frontend/checkout.html" },
    { "source": "/users", "destination": "/frontend/users.html" },
    { "source": "/payment-methods", "destination": "/frontend/payment-methods.html" },
    { "source": "/edit-dashboard", "destination": "/frontend/edit-dashboard.html" },
    { "source": "/audit-logs", "destination": "/frontend/audit-logs.html" },
    { "source": "/login", "destination": "/frontend/login.html" },
    { "source": "/onboarding", "destination": "/frontend/onboarding.html" },
    { "source": "/plan-selection", "destination": "/frontend/plan-selection.html" }
  ],
  "redirects": [
    { "source": "/dashboard.html", "destination": "/dashboard", "statusCode": 301 },
    { "source": "/invoices.html", "destination": "/invoices", "statusCode": 301 },
    { "source": "/order-management.html", "destination": "/order-management", "statusCode": 301 },
    { "source": "/queue-management.html", "destination": "/queue-management", "statusCode": 301 },
    { "source": "/products.html", "destination": "/products", "statusCode": 301 },
    { "source": "/services.html", "destination": "/services", "statusCode": 301 },
    { "source": "/reports.html", "destination": "/reports", "statusCode": 301 },
    { "source": "/settings.html", "destination": "/settings", "statusCode": 301 },
    { "source": "/permissions-management.html", "destination": "/permissions-management", "statusCode": 301 },
    { "source": "/sidebar-management.html", "destination": "/sidebar-management", "statusCode": 301 },
    { "source": "/coupon-management.html", "destination": "/coupon-management", "statusCode": 301 },
    { "source": "/flash-sale-management.html", "destination": "/flash-sale-management", "statusCode": 301 },
    { "source": "/client-dashboard.html", "destination": "/client-dashboard", "statusCode": 301 },
    { "source": "/client-orders.html", "destination": "/client-orders", "statusCode": 301 },
    { "source": "/shop.html", "destination": "/shop", "statusCode": 301 },
    { "source": "/cart.html", "destination": "/cart", "statusCode": 301 },
    { "source": "/reserve.html", "destination": "/reserve", "statusCode": 301 },
    { "source": "/vouchers.html", "destination": "/vouchers", "statusCode": 301 },
    { "source": "/checkout.html", "destination": "/checkout", "statusCode": 301 },
    { "source": "/users.html", "destination": "/users", "statusCode": 301 },
    { "source": "/payment-methods.html", "destination": "/payment-methods", "statusCode": 301 },
    { "source": "/edit-dashboard.html", "destination": "/edit-dashboard", "statusCode": 301 },
    { "source": "/audit-logs.html", "destination": "/audit-logs", "statusCode": 301 },
    { "source": "/onboarding.html", "destination": "/onboarding", "statusCode": 301 },
    { "source": "/plan-selection.html", "destination": "/plan-selection", "statusCode": 301 }
  ],
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/(.+)\\.html",
      "dest": "/frontend/$1.html"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    }
  ]
}
